# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mikrotik_dashboard
POSTGRES_USER=mikrotik_app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://mikrotik_app:change_me@postgres:5432/mikrotik_dashboard

# --- Auth / Security ---
JWT_SECRET_KEY=replace_with_random_64_char_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
FERNET_KEY=replace_with_generated_fernet_key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Seed super admin (created on first backend boot if no users exist) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me

# --- Default / seed router connection (placeholders only) ---
DEFAULT_ROUTER_NAME=RB4011-Main
DEFAULT_ROUTER_IP=192.0.2.1
DEFAULT_ROUTER_API_PORT=8728
DEFAULT_ROUTER_USERNAME=admin
DEFAULT_ROUTER_PASSWORD=change_me
SEED_DEFAULT_ROUTER=false

# --- SNMP (reserved for future, unused in v1) ---
SNMP_ENABLED=false
SNMP_COMMUNITY=

# --- Polling / Scheduler ---
DASHBOARD_POLL_INTERVAL_SECONDS=5
TRAFFIC_SNAPSHOT_INTERVAL_MINUTES=5
BACKUP_DAILY_HOUR=2
BACKUP_DAILY_MINUTE=0
ALERT_COOLDOWN_MINUTES_DEFAULT=15
CPU_ALERT_THRESHOLD=90
MEM_ALERT_THRESHOLD=90
ISP_PING_TARGETS=8.8.8.8,1.1.1.1

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id
# Inbound bot commands (/generate, /routers) — separate from TELEGRAM_ENABLED above,
# which only gates outbound alert notifications.
TELEGRAM_BOT_COMMANDS_ENABLED=false
# Comma-separated chat IDs allowed to run bot commands. Defaults to TELEGRAM_CHAT_ID if left empty.
TELEGRAM_ALLOWED_CHAT_IDS=

# --- SMTP / Email ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=change_me
SMTP_FROM_ADDRESS=alerts@example.com
SMTP_USE_TLS=true
ALERT_EMAIL_RECIPIENTS=admin@example.com

# --- Backups ---
BACKUP_STORAGE_DIR=/app/backups

# --- Domain / TLS (certbot) ---
DOMAIN=dashboard.example.com
CERTBOT_EMAIL=admin@example.com

# --- Frontend (build-time / injected) ---
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://dashboard.example.com,http://localhost:5173
